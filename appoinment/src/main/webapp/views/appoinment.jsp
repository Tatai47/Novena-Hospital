    <section class="appoinment section">
        <div class="container">
            <div class="row">
                <div class="col-lg-4">
                    <div class="mt-3">
                        <div class="feature-icon mb-3">
                            <i class="icofont-support text-lg"></i>
                        </div>
                        <span class="h3">Call for an Emergency Service!</span>
                        <h2 class="text-color mt-3">+84 789 1256 </h2>
                    </div>
                </div>

                <div class="col-lg-8">
                    <div class="appoinment-wrap mt-5 mt-lg-0 pl-lg-5">
                        <h2 class="mb-2 title-color">Book an appointment</h2>
                        <p class="mb-4">Schedule your visit with our expert medical team. Please fill out the form below
                            with your details, preferred date, and department, and our support staff will confirm your
                            appointment shortly.</p>
                        <form id="#" class="appoinment-form" method="post" action="confirmation">
                            <div class="row">
                                <div class="col-lg-6">
                                    <div class="form-group">
                                        <select class="form-control" id="exampleFormControlSelect1" name="department">
                                            <option>Choose Department</option>
                                            <option name="two" value="Cardiology">Cardiology</option>
                                            <option name="three" value="Neurology">Neurology</option>
                                            <option name="four" value="Orthopedics">Orthopedics</option>
                                            <option name="five" value="Pediatrics">Pediatrics</option>
                                            <option name="six" value="Gynecology">Gynecology</option>
                                            <option name="seven" value="General Surgery">General Surgery</option>
                                            <option name="eight" value="Dental Care">Dental Care</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-lg-6">
                                    <div class="form-group">
                                        <select class="form-control" id="exampleFormControlSelect2" name="doctors">
                                            <option>Select Doctors</option>
                                            <option name="two" value="Dr. John Marshal">Dr. John Marshal</option>
                                            <option name="three" value="Dr. Marshal Root">Dr. Marshal Root</option>
                                            <option name="four" value="Dr. Siamon John">Dr. Siamon John</option>
                                            <option name="five" value="Dr. Rishat Ahmed">Dr. Rishat Ahmed</option>
                                            <option name="six" value="Dr. Sarah Johnson">Dr. Sarah Johnson</option>
                                            <option name="seven" value="Dr. Michael Smith">Dr. Michael Smith</option>
                                            <option name="eight" value="Dr. Emily Davis">Dr. Emily Davis</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="col-lg-6">
                                    <div class="form-group">
                                        <input name="date" id="date" type="date" class="form-control" required>
                                    </div>
                                </div>

                                <div class="col-lg-6">
                                    <div class="form-group">
                                        <input name="time" id="time" type="time" class="form-control" min="07:00"
                                            max="23:00" required>
                                    </div>
                                </div>
                                <div class="col-lg-6">
                                    <div class="form-group">
                                        <input name="name" id="name" type="text" class="form-control"
                                            placeholder="Full Name" required>
                                    </div>
                                </div>

                                <div class="col-lg-6">
                                    <div class="form-group">
                                        <input name="phone" id="phone" type="Number" class="form-control"
                                            placeholder="Phone Number" required>
                                    </div>
                                </div>
                            </div>
                            <div class="form-group-2 mb-4">
                                <textarea name="message" id="message" class="form-control" rows="6"
                                    placeholder="Your Message"></textarea>
                            </div>
                            <button class="btn btn-main btn-round-full" type="submit">
                                Make Appointment
                                <i class="icofont-simple-right ml-2"></i></button>

                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>


